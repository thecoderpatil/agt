# AGT Equities — environment variable sample
#
# Copy to `.env` (or set in the NSSM service environment) and fill in
# secrets. Anything listed here with a non-empty default is the production
# default — change only if you know why.

# =============================================================================
# Decoupling Sprint A — scheduler daemon cutover flag (Unit A5e)
# =============================================================================
#
# USE_SCHEDULER_DAEMON controls the atomic cutover of scheduler-owned jobs
# from the Telegram bot process to the standalone `agt_scheduler` daemon.
#
# Jobs gated by this flag (bot-side registration no-ops when set):
#   - attested_sweeper       (60s — scheduler-side landed in A5a)
#   - el_snapshot_writer     (30s — scheduler-side landed in A5d.d,
#                             with APEX_SURVIVAL alerts routed through
#                             the cross_daemon_alerts bus)
#
# Jobs that are already scheduler-only (not gated, never ran in bot):
#   - heartbeat_writer       (60s, A2)
#   - orphan_sweep           (5 min, A2)
#
# Jobs that stay bot-owned under both flag states:
#   - cross_daemon_alerts_drain (2s drain consumer — Telegram delivery
#                                path belongs on the bot side).
#   - attested_poller, staged_alert_flush, and every daily/monthly job.
#
# Default: 0 (OFF). During the 4-week cutover window per DT Q1a-g, the
# scheduler daemon stays dormant and every gated job continues to run
# inside the bot. To flip:
#
#   1. Set USE_SCHEDULER_DAEMON=1 in BOTH process environments
#      (bot + scheduler).
#   2. Restart the bot service first (it will skip gated registrations).
#   3. Start the `agt_scheduler` NSSM service.
#   4. Verify:
#        - agt_scheduler pid logged to logs/agt_scheduler.log.
#        - `SELECT * FROM daemon_heartbeat WHERE daemon_name='agt_scheduler'`
#          shows age_seconds < 90.
#        - Bot startup logs contain
#          "Skipped attested_sweeper registration: USE_SCHEDULER_DAEMON=1"
#          and likewise for el_snapshot_writer.
#
# Rollback: set USE_SCHEDULER_DAEMON=0, stop `agt_scheduler` service,
# restart bot. The bot re-registers every gated job on next startup.
USE_SCHEDULER_DAEMON=0

# Scheduler IB client id (scheduler owns clientId=2, bot owns clientId=1).
# SCHEDULER_IB_CLIENT_ID=2

# =============================================================================
# IBKR / paper-mode
# =============================================================================
# PAPER_MODE=1

# =============================================================================
# Telegram bot secrets (DO NOT COMMIT real values)
# =============================================================================
# TELEGRAM_BOT_TOKEN=
# AUTHORIZED_USER_ID=
# ANTHROPIC_API_KEY=

# Sprint B4: three-stage FA-block-aware inception_delta resolver.
# "1" (default) = use pending_order_children join chain (FA-block safe).
# "0"           = fall back to pre-B4 flat pending_orders lookup
#                   (preserved for 2 sprints as rollback kill switch).
USE_FA_BLOCK_CHILDREN_READER=1
